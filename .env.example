# DropCore Configuration
# Copy to .env and fill in your values

# App
SECRET_KEY=change-me-to-a-random-string
DEMO_MODE=true   # Set false for live integrations

# CJDropshipping (free account at app.cjdropshipping.com)
CJ_EMAIL=your@email.com
CJ_PASSWORD=yourpassword

# WooCommerce (Settings → Advanced → REST API)
WC_URL=https://yourstore.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxx

# Claude / Anthropic (claude.ai → API keys)
# Used by MarketingContentAgent + CustomerServiceAgent
# claude-haiku-4-5 costs ~$0.01 per product — very cheap
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Brevo SMTP (brevo.com — 300 free emails/day)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-brevo-smtp-key
EMAIL_FROM=noreply@yourstore.com
EMAIL_FROM_NAME=YourStore

# Slack webhook (api.slack.com/apps → Incoming Webhooks — free)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# IMAP (for CustomerServiceAgent to read inbound emails)
IMAP_HOST=imap.gmail.com
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your-app-password
